{
  "template_name": "Printer Not Working",
  "tier": "L1",
  "priority": "P3",
  "category": "Hardware",
  "estimated_resolution": "15 minutes",
  "fields": {
    "title": "[Printer] {user_name} - {printer_name} Issues",
    "description": "User unable to print to network or local printer.",
    "affected_user": {
      "name": "",
      "location": "",
      "device_type": "Windows/Mac",
      "printer_name": "",
      "printer_ip": ""
    },
    "issue_details": {
      "error_message": "",
      "print_queue_stuck": false,
      "printer_offline": false,
      "driver_version": "",
      "symptoms": [
        "Nothing happens when printing",
        "Jobs stuck in queue",
        "Printer shows offline",
        "Partial prints",
        "Print quality issues"
      ]
    },
    "troubleshooting_steps": [
      "1. Check printer power and connectivity",
      "2. Ping printer IP address",
      "3. Clear print queue",
      "4. Restart print spooler service",
      "5. Remove and re-add printer",
      "6. Update printer driver",
      "7. Test with different document"
    ],
    "printer_diagnostics": {
      "printer_responds_to_ping": false,
      "print_spooler_running": false,
      "driver_installed": false,
      "test_page_successful": false
    }
  },
  "sla": {
    "response_time": "30 minutes",
    "resolution_time": "1 hour"
  },
  "escalation_triggers": [
    "Printer hardware failure",
    "Network printer unreachable",
    "Multiple users affected",
    "Print server issues"
  ],
  "related_runbooks": [
    "references/l1-runbooks.md#printer-issues"
  ],
  "common_commands": {
    "windows": [
      "net stop spooler",
      "net start spooler",
      "ping {printer_ip}"
    ],
    "macos": [
      "lpstat -p",
      "cancel -a",
      "sudo launchctl stop org.cups.cupsd"
    ]
  }
}
